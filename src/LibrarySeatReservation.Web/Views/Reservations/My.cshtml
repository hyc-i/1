@model ReservationListViewModel
@{
    ViewData["Title"] = "我的预约";
}

<h2>我的预约</h2>

@if (Model.Items.Count == 0)
{
    <div class="alert alert-info">暂无预约记录。</div>
    <a asp-controller="Seats" asp-action="Index" class="btn btn-primary">去预约</a>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>座位</th>
                    <th>区域</th>
                    <th>日期</th>
                    <th>时段</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.SeatNumber</td>
                        <td>@item.Area</td>
                        <td>@item.ReservationDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.StartTime.ToString("HH:mm") - @item.EndTime.ToString("HH:mm")</td>
                        <td>
                            <span class="badge @(item.Status == "预约中" ? "bg-success" : "bg-secondary")">@item.Status</span>
                        </td>
                        <td>
                            @if (item.CanCancel)
                            {
                                <form asp-action="Cancel" asp-route-id="@item.Id" method="post" onsubmit="return confirm('确定取消此预约？')">
                                    <button type="submit" class="btn btn-danger btn-sm">取消</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
