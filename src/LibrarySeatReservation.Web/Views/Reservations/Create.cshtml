@model ReservationCreateViewModel
@{
    ViewData["Title"] = "预约座位";
}

<h2>预约座位 - @Model.SeatNumber</h2>

<div class="row">
    <div class="col-md-6">
        <form method="post" asp-action="Create">
            <input type="hidden" asp-for="SeatId" />
            <input type="hidden" asp-for="SeatNumber" />

            <div class="mb-3">
                <label asp-for="ReservationDate" class="form-label"></label>
                <input asp-for="ReservationDate" class="form-control" type="date" />
                <span asp-validation-for="ReservationDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StartTime" class="form-label">开始时间</label>
                <input asp-for="StartTime" class="form-control" type="time" />
                <span asp-validation-for="StartTime" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EndTime" class="form-label">结束时间</label>
                <input asp-for="EndTime" class="form-control" type="time" />
                <span asp-validation-for="EndTime" class="text-danger"></span>
            </div>

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <button type="submit" class="btn btn-primary">确认预约</button>
            <a asp-controller="Seats" asp-action="Index" class="btn btn-outline-secondary">取消</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
