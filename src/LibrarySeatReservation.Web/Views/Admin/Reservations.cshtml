@model AdminReservationsViewModel
@{
    ViewData["Title"] = "预约管理";
    Layout = "_AdminLayout";
}

<h2>预约管理</h2>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <select name="status" class="form-select" onchange="this.form.submit()">
            <option value="">全部状态</option>
            @foreach (var s in Model.StatusFilter!.Items)
            {
                <option value="@s" selected="@(string.Equals(Model.CurrentStatus, s))">@s</option>
            }
        </select>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>座位</th>
                <th>区域</th>
                <th>学生</th>
                <th>日期</th>
                <th>时段</th>
                <th>状态</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.SeatNumber</td>
                    <td>@item.Area</td>
                    <td>@item.StudentName</td>
                    <td>@item.ReservationDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.StartTime.ToString("HH:mm") - @item.EndTime.ToString("HH:mm")</td>
                    <td><span class="badge @(item.Status == "预约中" ? "bg-primary" : "bg-secondary")">@item.Status</span></td>
                    <td>
                        @if (item.CanCancel)
                        {
                            <form asp-action="Cancel" asp-route-id="@item.Id" method="post" onsubmit="return confirm('确定取消该预约？')">
                                <button type="submit" class="btn btn-danger btn-sm">取消</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.Items.Count == 0)
{
    <p class="text-muted">暂无预约记录。</p>
}
