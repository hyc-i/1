@model AdminStatisticsViewModel
@{
    ViewData["Title"] = "统计";
}

<h2>数据统计</h2>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mb-4">
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h3 class="text-primary">@Model.TotalSeats</h3>
                <p class="text-muted">总座位数</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h3 class="text-success">@Model.TodayReservations</h3>
                <p class="text-muted">今日预约数</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h3 class="text-info">@Model.UtilizationRate%</h3>
                <p class="text-muted">座位利用率</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h3 class="text-warning">@(Model.HotArea ?? "-")</h3>
                <p class="text-muted">热门区域</p>
            </div>
        </div>
    </div>
</div>

<div>
    <a asp-action="Reservations" class="btn btn-outline-primary">返回预约管理</a>
</div>
