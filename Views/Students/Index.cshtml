@model IEnumerable<Student>
@{
    ViewData["Title"] = "学生档案";
    var students = Model.ToList();
}

<section class="page-heading compact">
    <p class="eyebrow">Roster</p>
    <h1>学生基本信息管理</h1>
    <p>完成学生档案的增加、删除、修改、查询与批量导入。</p>
</section>

<div class="toolbar">
    <form method="get" class="search-form">
        <input class="form-control" name="keyword" value="@ViewBag.Keyword" placeholder="按学号、姓名、学院、专业或班级查询" />
        <button class="btn btn-ink" type="submit">查询</button>
        <a class="btn btn-paper" asp-action="Index">重置</a>
    </form>
    <div class="hero-actions m-0">
        <a class="btn btn-paper" asp-action="Import">批量导入</a>
        <a class="btn btn-ink" asp-action="Create">新增学生</a>
    </div>
</div>

<section class="table-card">
    @if (students.Count == 0)
    {
        <div class="empty-state">暂无学生档案，请先新增或导入学生。</div>
    }
    else
    {
        <table class="ledger-table">
            <thead>
                <tr>
                    <th>学生</th>
                    <th>学院 / 专业</th>
                    <th>班级</th>
                    <th>联系方式</th>
                    <th class="text-end">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in students)
                {
                    <tr>
                        <td>
                            <span class="identity"><strong>@item.Name</strong><small>@item.StudentNo · @item.Gender</small></span>
                        </td>
                        <td>@item.College<br /><small>@item.Major</small></td>
                        <td>@item.ClassName</td>
                        <td>@item.Phone<br /><small>@item.Email</small></td>
                        <td>
                            <div class="table-actions">
                                <a class="btn btn-paper" asp-action="Details" asp-route-id="@item.Id">档案</a>
                                <a class="btn btn-paper" asp-action="Edit" asp-route-id="@item.Id">编辑</a>
                                <a class="btn btn-ink" asp-controller="ActivityRecords" asp-action="Create" asp-route-studentId="@item.Id">登记</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('确认删除该学生及其所有第二课堂记录？');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-danger-soft" type="submit">删除</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>
