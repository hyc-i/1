@model Student
@{
    ViewData["Title"] = "编辑学生档案";
}

<section class="page-heading compact">
    <p class="eyebrow">Student</p>
    <h1>编辑学生档案</h1>
    <p>维护学生基本信息，关联的第二课堂记录将继续保留。</p>
</section>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="form-card">
    @Html.AntiForgeryToken()
    <partial name="_StudentForm" model="Model" />
    <div class="hero-actions">
        <button class="btn btn-ink" type="submit">保存修改</button>
        <a class="btn btn-paper" asp-action="Details" asp-route-id="@Model.Id">查看档案</a>
        <a class="btn btn-paper" asp-action="Index">返回列表</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
