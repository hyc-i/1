@model ActivityRecord
@{
    ViewData["Title"] = "编辑登记记录";
}

<section class="page-heading compact">
    <p class="eyebrow">Record</p>
    <h1>编辑第二课堂记录</h1>
    <p>学生只能修改待审核申请；已审核记录和学分认定由管理员通过审核授分流程处理。</p>
</section>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="form-card">
    @Html.AntiForgeryToken()
    <partial name="_ActivityForm" model="Model" />
    <div class="hero-actions">
        <button class="btn btn-ink" type="submit">保存修改</button>
        <a class="btn btn-paper" asp-action="Details" asp-route-id="@Model.Id">查看详情</a>
        @if (User.IsInRole("Student"))
        {
            <a class="btn btn-paper" asp-controller="StudentPortal" asp-action="Index">返回学生主页</a>
        }
        else
        {
            <a class="btn btn-paper" asp-action="Index">返回记录</a>
        }
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
