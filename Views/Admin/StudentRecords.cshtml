@model IEnumerable<ActivityRecord>
@{
    var student = ViewBag.Student as Student;
    ViewData["Title"] = "学生登记明细";
    var records = Model.ToList();
    var totalCredits = records.Where(x => x.Status == ActivityOptions.ApprovedStatus).Sum(x => x.Credits);
}

<section class="page-heading compact">
    <p class="eyebrow">Student Detail</p>
    <h1>@student?.Name 的登记明细</h1>
    <p>@student?.StudentNo · @student?.College @student?.Major @student?.ClassName · 累计 @totalCredits.ToString("0.0") 学分</p>
</section>

<div class="toolbar">
    <a class="btn btn-paper" asp-action="Index">返回管理员查询</a>
    <a class="btn btn-ink" asp-controller="ActivityRecords" asp-action="Create" asp-route-studentId="@student?.Id">新增登记</a>
</div>

<section class="table-card">
    @if (records.Count == 0)
    {
        <div class="empty-state">该学生暂无第二课堂登记记录。</div>
    }
    else
    {
        <table class="ledger-table">
            <thead>
                <tr>
                    <th>活动</th>
                    <th>类别</th>
                    <th>时间</th>
                    <th>状态</th>
                    <th>学分</th>
                    <th class="text-end">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in records)
                {
                    var statusClass = item.Status == ActivityOptions.ApprovedStatus ? "approved" : item.Status == ActivityOptions.RejectedStatus ? "rejected" : "pending";
                    <tr>
                        <td><span class="identity"><strong>@item.ActivityName</strong><small>@item.Organizer</small></span></td>
                        <td>@item.Category<br /><small>@item.Level</small></td>
                        <td>@item.StartDate?.ToString("yyyy-MM-dd")<br /><small>@item.EndDate?.ToString("yyyy-MM-dd")</small></td>
                        <td><span class="status-badge @statusClass">@item.Status</span></td>
                        <td>@item.Credits.ToString("0.0")</td>
                        <td><div class="table-actions"><a class="btn btn-paper" asp-controller="ActivityRecords" asp-action="Details" asp-route-id="@item.Id">详情</a><a class="btn btn-ink" asp-controller="ActivityRecords" asp-action="Review" asp-route-id="@item.Id">审核</a></div></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>
